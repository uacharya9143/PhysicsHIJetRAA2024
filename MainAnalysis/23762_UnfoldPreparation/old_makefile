Execute: PrepareUnfold.cpp
	 g++ PrepareUnfold.cpp -o Execute `root-config --libs --cflags` \
	-I$(ProjectBase)/CommonCode/include \
	$(ProjectBase)/CommonCode/library/*.o 

ExecutePreset: RunPreset.cpp
